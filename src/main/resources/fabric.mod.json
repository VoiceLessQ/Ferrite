{
	"schemaVersion": 1,
	"id": "ferrite",
	"version": "${version}",
	"name": "Ferrite",
	"description": "Performance research mod — Rust-powered diagnostics and world features for Minecraft. Logs chunk gen and entity render costs to console.",
	"authors": [
		"NoZeroG"
	],
	"contact": {
		"issues": ""
	},
	"license": "MIT",
	"icon": "assets/ferrite/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"me.apika.apikaprobe.bridge.ExampleMod"
		],
		"client": [
			"me.apika.apikaprobe.ExampleModClient"
		]
	},
	"mixins": [
		"ferrite.mixins.json",
		{
			"config": "ferrite.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1.1 <26.2",
		"java": ">=21",
		"fabric-api": "*"
	},
	"suggests": { }
}
